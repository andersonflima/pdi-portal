{
  "name": "@pdi/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:push": "node ../../scripts/ensure-api-data-dir.mjs && prisma db push",
    "db:seed": "node ../../scripts/ensure-api-data-dir.mjs && tsx prisma/seed.ts",
    "dev": "tsx watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/websocket": "^11.2.0",
    "@pdi/contracts": "file:../../packages/contracts",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "prisma": "^6.7.0",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.1.3"
  },
  "overrides": {
    "esbuild": "0.27.3"
  }
}
