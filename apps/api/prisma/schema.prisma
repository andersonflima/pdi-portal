generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum PdiStatus {
  DRAFT
  ACTIVE
  DONE
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(MEMBER)
  pdiPlans     PdiPlan[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PdiPlan {
  id        String    @id @default(cuid())
  ownerId   String
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title     String
  objective String
  status    PdiStatus @default(DRAFT)
  dueDate   DateTime?
  board     Board?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Board {
  id        String   @id @default(cuid())
  pdiPlanId String   @unique
  pdiPlan   PdiPlan  @relation(fields: [pdiPlanId], references: [id], onDelete: Cascade)
  title     String
  nodes     Json
  edges     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
